---
import { getCollection } from 'astro:content';

import PostCard from '@/components/PostCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { site } from '@/config/site';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { byProjectOrder, byPublishedDesc } from '@/utils/content';

const projects = (await getCollection('projects'))
  .filter((project) => project.data.featured)
  .sort(byProjectOrder);
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort(byPublishedDesc)
  .slice(0, 3);
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebSite', name: site.name, url: site.url, inLanguage: site.language },
    { '@type': 'Person', name: site.author, url: site.url, sameAs: [site.github] },
  ],
};
---

<BaseLayout structuredData={structuredData}>
  <section class="site-shell hero">
    <div>
      <p class="eyebrow">AI APPLICATIONS · AGENT WORKFLOWS · LOCAL-FIRST</p>
      <h1 class="display-title">把 AI 的能力，放进可控的系统里。</h1>
      <p class="lede">
        我是 yuyukosama2004。我在构建可控、可验证、local-first 的 AI 应用与 Agent
        开发工具，也在这里记录真实的架构取舍与开发实践。
      </p>
      <div class="button-row">
        <a class="button primary" href="/projects">查看项目</a>
        <a class="button" href={site.github} target="_blank" rel="noreferrer">访问 GitHub ↗</a>
      </div>
    </div>
    <aside class="signal-card panel" aria-label="当前关注方向">
      <span class="status"><i></i> currently building</span>
      <dl>
        <div><dt>01</dt><dd>Human-in-the-loop AI</dd></div>
        <div><dt>02</dt><dd>Evidence-backed research</dd></div>
        <div><dt>03</dt><dd>Guarded agent workflows</dd></div>
      </dl>
    </aside>
  </section>

  <section class="site-shell section-heading">
    <div>
      <p class="eyebrow">SELECTED WORK</p><h2 class="section-title">
        项目不只是代码仓库，而是问题、边界与结果。
      </h2>
    </div>
    <a class="text-link" href="/projects">浏览全部项目 →</a>
  </section>
  <section class="site-shell project-grid" aria-label="精选项目">
    {projects.map((project, index) => <ProjectCard project={project} index={index} />)}
  </section>

  <section class="site-shell notes-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">LATEST NOTES</p><h2 class="section-title">
          从实现里提炼可以复用的判断。
        </h2>
      </div><a class="text-link" href="/blog">阅读全部文章 →</a>
    </div>
    <div>{posts.map((post) => <PostCard post={post} />)}</div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    min-height: min(49rem, calc(100vh - 4.5rem));
    grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.55fr);
    align-items: center;
    gap: clamp(2rem, 7vw, 7rem);
    padding-block: 6rem;
  }
  .lede {
    margin: 2rem 0;
  }
  .signal-card {
    padding: 1.35rem;
    transform: rotate(1.5deg);
  }
  .status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .status i {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0.28rem var(--accent-soft);
  }
  dl {
    margin: 3.5rem 0 0;
  }
  dl div {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    padding: 1rem 0;
    border-top: 1px solid var(--line);
    gap: 0.75rem;
  }
  dt {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }
  dd {
    margin: 0;
    font-weight: 700;
  }
  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
  }
  section.section-heading {
    padding-block: 5rem 2rem;
  }
  .section-heading h2 {
    max-width: 18ch;
  }
  .text-link {
    color: var(--accent-strong);
    font-weight: 700;
    white-space: nowrap;
  }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .notes-section {
    padding-block: 8rem 5rem;
  }
  .notes-section > .section-heading {
    margin-bottom: 2rem;
  }
  @media (max-width: 52rem) {
    .hero {
      min-height: auto;
      grid-template-columns: 1fr;
      padding-block: 5rem;
    }
    .signal-card {
      transform: none;
    }
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 36rem) {
    .section-heading {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
