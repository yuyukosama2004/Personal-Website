---
import { getCollection } from 'astro:content';
import PostCard from '@/components/PostCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { byPublishedDesc, uniqueTags } from '@/utils/content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(byPublishedDesc);
const tags = uniqueTags(posts);
---

<BaseLayout title="博客" description="关于 AI 应用、Agent 工作流与全栈工程的开发记录。">
  <section class="site-shell page-intro">
    <p class="eyebrow">NOTES & ESSAYS</p><h1 class="display-title">博客</h1><p class="lede">
      记录项目背后的工程判断、失败路径和可以复用的方法，而不是重新包装产品说明。
    </p><nav aria-label="文章标签">{tags.map((tag) => <a href={`/tags/${tag}/`}>#{tag}</a>)}</nav>
  </section>
  <section class="site-shell posts" aria-label="文章列表">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>

<style>
  .page-intro {
    padding-block: 8rem 4rem;
  }
  nav {
    display: flex;
    flex-wrap: wrap;
    margin-top: 2rem;
    gap: 0.6rem;
  }
  nav a {
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-decoration: none;
  }
  .posts {
    padding-bottom: 6rem;
  }
</style>
