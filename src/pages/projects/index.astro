---
import { getCollection } from 'astro:content';
import ProjectCard from '@/components/ProjectCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { byProjectOrder } from '@/utils/content';

const projects = (await getCollection('projects')).sort(byProjectOrder);
const featured = projects.filter((project) => project.data.featured);
const labs = projects.filter((project) => !project.data.featured);
---

<BaseLayout title="项目" description="正在构建的 AI 应用、研究工具与 Agent 工程项目。">
  <section class="site-shell page-intro">
    <p class="eyebrow">PROJECTS</p><h1 class="display-title">项目</h1><p class="lede">
      这里展示的不只是技术栈，还包括每个项目试图解决的问题、关键边界和当前进展。
    </p>
  </section>
  <section class="site-shell">
    <h2 class="section-title">重点项目</h2><div class="project-grid">
      {featured.map((project, index) => <ProjectCard project={project} index={index} />)}
    </div>
  </section>
  <section class="site-shell lab-section">
    <p class="eyebrow">LAB & PRACTICE</p><h2 class="section-title">实验与工程实践</h2><div
      class="project-grid"
    >
      {
        labs.map((project, index) => (
          <ProjectCard project={project} index={featured.length + index} />
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .page-intro {
    padding-block: 8rem 5rem;
  }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 2rem;
    gap: 1rem;
  }
  .lab-section {
    padding-block: 8rem 5rem;
  }
  @media (max-width: 52rem) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
