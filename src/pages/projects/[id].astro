---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import PostCard from '@/components/PostCard.astro';
import SystemMap from '@/components/SystemMap.astro';
import { site } from '@/config/site';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { projectStatusLabel } from '@/utils/projects';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { id: project.id }, props: { project } }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { Content } = await render(project);
const posts = (await getCollection('blog', ({ data }) => !data.draft)).filter(
  (post) => post.data.project === project.id,
);
const canonical = `${site.url}/projects/${project.id}/`;
const statusLabel = projectStatusLabel(project.data);
const activityLabels = { active: '持续开发', maintained: '维护中', paused: '暂停开发' };
const demoLabels = { public: '公开演示', internal: '内部演示', unavailable: '暂无公开演示' };
const evidenceLabels = { verified: '已核验证据', partial: '部分证据', planned: '计划补充' };
const structuredData = {
  '@context': 'https://schema.org',
  '@type': project.data.githubUrl ? 'SoftwareSourceCode' : 'CreativeWork',
  name: project.data.name,
  description: project.data.summary,
  url: canonical,
  codeRepository: project.data.githubUrl ?? undefined,
  ...(project.data.githubUrl ? { programmingLanguage: project.data.tech } : {}),
};
---

<BaseLayout
  title={project.data.name}
  description={project.data.summary}
  structuredData={structuredData}
>
  <article>
    <header class="site-shell project-hero" style={`--project-accent:${project.data.accent}`}>
      <div>
        <a class="back" href="/projects">← 全部项目</a><p class="eyebrow">
          {statusLabel}
        </p><h1>{project.data.name}</h1><p class="lede">{project.data.tagline}</p><div
          class="button-row"
        >
          {
            project.data.githubUrl && (
              <a
                class="button primary"
                href={`/go/github/${project.id}`}
                target="_blank"
                rel="noreferrer"
              >
                查看公开仓库 ↗
              </a>
            )
          }{
            project.data.demoUrl && (
              <a class="button" href={project.data.demoUrl} target="_blank" rel="noreferrer">
                打开演示 ↗
              </a>
            )
          }{!project.data.githubUrl && <span class="private-note">当前为私有开发仓库</span>}
        </div>
        <dl class="project-meta">
          <div><dt>类型</dt><dd>{project.data.category}</dd></div>
          <div><dt>角色</dt><dd>个人项目 · 独立完成</dd></div>
          <div><dt>状态</dt><dd>{activityLabels[project.data.activity]}</dd></div>
          <div><dt>演示</dt><dd>{demoLabels[project.data.demoStatus]}</dd></div>
        </dl>
      </div>
      <div class="project-mark" aria-hidden="true">
        {project.data.name.slice(0, 2).toUpperCase()}
      </div>
    </header>
    <div class="reading-shell project-body">
      <p class="summary">{project.data.summary}</p><ul class="tech" aria-label="技术栈">
        {project.data.tech.map((item) => <li>{item}</li>)}
      </ul>
      <section class="evidence-panel panel" aria-labelledby="evidence-heading">
        <div>
          <p class="eyebrow">EVIDENCE</p>
          <h2 id="evidence-heading">{evidenceLabels[project.data.evidence]}</h2>
        </div>
        {
          project.data.evidenceStats.length > 0 ? (
            <dl>
              {project.data.evidenceStats.map((stat) => (
                <div>
                  <dt>{stat.value}</dt>
                  <dd>
                    {stat.label} · {stat.measuredAt.toISOString().slice(0, 10)}
                  </dd>
                </div>
              ))}
            </dl>
          ) : (
            <p>真实界面与可复现材料仍在整理；当前页面不使用虚构截图或未经验证的数字。</p>
          )
        }
      </section>
      <SystemMap items={project.data.flow} accent={project.data.accent} /><div
        class="prose-content"
      >
        <Content />
      </div>
    </div>
  </article>
  {
    posts.length > 0 && (
      <section class="site-shell related">
        <h2 class="section-title">相关开发笔记</h2>
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </section>
    )
  }
</BaseLayout>

<style>
  .project-hero {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    min-height: 35rem;
    padding-block: 7rem 4rem;
    gap: 3rem;
  }
  .back {
    display: inline-block;
    margin-bottom: 4rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-decoration: none;
  }
  h1 {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(3rem, 9vw, 7rem);
    letter-spacing: -0.07em;
    line-height: 0.9;
  }
  .project-mark {
    display: grid;
    width: clamp(9rem, 20vw, 15rem);
    aspect-ratio: 1;
    place-items: center;
    border-radius: 50%;
    background: color-mix(in srgb, var(--project-accent) 18%, transparent);
    color: var(--project-accent);
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 800;
    transform: rotate(8deg);
  }
  .private-note {
    align-self: center;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }
  .project-meta {
    display: grid;
    max-width: 42rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 3rem 0 0;
    gap: 1px;
    background: var(--line);
  }
  .project-meta div {
    padding: 0.8rem;
    background: var(--bg);
  }
  .project-meta dt {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
  }
  .project-meta dd {
    margin: 0.25rem 0 0;
    font-size: 0.82rem;
    font-weight: 700;
  }
  .project-body {
    padding-block: 4rem 7rem;
  }
  .summary {
    margin: 0 0 2rem;
    font-size: 1.3rem;
    font-weight: 650;
  }
  .tech {
    display: flex;
    flex-wrap: wrap;
    margin: 0 0 4rem;
    padding: 0;
    gap: 0.5rem;
    list-style: none;
  }
  .tech li {
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }
  .evidence-panel {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    margin-bottom: 4rem;
    padding: 1.4rem;
    gap: 2rem;
  }
  .evidence-panel h2,
  .evidence-panel p {
    margin: 0;
  }
  .evidence-panel > p {
    max-width: 30rem;
    color: var(--muted);
  }
  .evidence-panel dl {
    display: flex;
    margin: 0;
    gap: 1.5rem;
  }
  .evidence-panel dl div {
    display: grid;
  }
  .evidence-panel dt {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 800;
  }
  .evidence-panel dd {
    margin: 0;
    color: var(--muted);
    font-size: 0.68rem;
  }
  .prose-content :global(h2) {
    margin: 3rem 0 1rem;
    font-size: 2rem;
    letter-spacing: -0.04em;
  }
  .prose-content :global(p),
  .prose-content :global(li) {
    color: var(--muted);
  }
  .related {
    padding-bottom: 6rem;
  }
  @media (max-width: 42rem) {
    .project-hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .project-mark {
      width: 8rem;
    }
    .project-meta {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .evidence-panel {
      grid-template-columns: 1fr;
    }
    .evidence-panel dl {
      flex-wrap: wrap;
    }
  }
</style>
