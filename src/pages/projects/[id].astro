---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import PostCard from '@/components/PostCard.astro';
import SystemMap from '@/components/SystemMap.astro';
import { site } from '@/config/site';
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { id: project.id }, props: { project } }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { Content } = await render(project);
const posts = (await getCollection('blog', ({ data }) => !data.draft)).filter(
  (post) => post.data.project === project.id,
);
const canonical = `${site.url}/projects/${project.id}/`;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: project.data.name,
  description: project.data.summary,
  url: canonical,
  codeRepository: project.data.githubUrl ?? undefined,
  programmingLanguage: project.data.tech,
};
---

<BaseLayout
  title={project.data.name}
  description={project.data.summary}
  structuredData={structuredData}
>
  <article>
    <header class="site-shell project-hero" style={`--project-accent:${project.data.accent}`}>
      <div>
        <a class="back" href="/projects">← 全部项目</a><p class="eyebrow">
          {project.data.category} · {project.data.status}
        </p><h1>{project.data.name}</h1><p class="lede">{project.data.tagline}</p><div
          class="button-row"
        >
          {
            project.data.githubUrl && (
              <a
                class="button primary"
                href={`/go/github/${project.id}`}
                target="_blank"
                rel="noreferrer"
              >
                查看源码 ↗
              </a>
            )
          }{
            project.data.demoUrl && (
              <a class="button" href={project.data.demoUrl} target="_blank" rel="noreferrer">
                打开演示 ↗
              </a>
            )
          }{!project.data.githubUrl && <span class="private-note">当前为私有开发仓库</span>}
        </div>
      </div>
      <div class="project-mark" aria-hidden="true">
        {project.data.name.slice(0, 2).toUpperCase()}
      </div>
    </header>
    <div class="reading-shell project-body">
      <p class="summary">{project.data.summary}</p><ul class="tech" aria-label="技术栈">
        {project.data.tech.map((item) => <li>{item}</li>)}
      </ul><SystemMap items={project.data.flow} accent={project.data.accent} /><div
        class="prose-content"
      >
        <Content />
      </div>
    </div>
  </article>
  {
    posts.length > 0 && (
      <section class="site-shell related">
        <h2 class="section-title">相关开发笔记</h2>
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </section>
    )
  }
</BaseLayout>

<style>
  .project-hero {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    min-height: 35rem;
    padding-block: 7rem 4rem;
    gap: 3rem;
  }
  .back {
    display: inline-block;
    margin-bottom: 4rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-decoration: none;
  }
  h1 {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(3rem, 9vw, 7rem);
    letter-spacing: -0.07em;
    line-height: 0.9;
  }
  .project-mark {
    display: grid;
    width: clamp(9rem, 20vw, 15rem);
    aspect-ratio: 1;
    place-items: center;
    border-radius: 50%;
    background: color-mix(in srgb, var(--project-accent) 18%, transparent);
    color: var(--project-accent);
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 800;
    transform: rotate(8deg);
  }
  .private-note {
    align-self: center;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }
  .project-body {
    padding-block: 4rem 7rem;
  }
  .summary {
    margin: 0 0 2rem;
    font-size: 1.3rem;
    font-weight: 650;
  }
  .tech {
    display: flex;
    flex-wrap: wrap;
    margin: 0 0 4rem;
    padding: 0;
    gap: 0.5rem;
    list-style: none;
  }
  .tech li {
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }
  .prose-content :global(h2) {
    margin: 3rem 0 1rem;
    font-size: 2rem;
    letter-spacing: -0.04em;
  }
  .prose-content :global(p),
  .prose-content :global(li) {
    color: var(--muted);
  }
  .related {
    padding-bottom: 6rem;
  }
  @media (max-width: 42rem) {
    .project-hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .project-mark {
      width: 8rem;
    }
  }
</style>
