---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ProjectDetailPage from '@/components/pages/ProjectDetailPage.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { id: project.id }, props: { project } }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { Content } = await render(project);
const posts = (await getCollection('blog', ({ data }) => !data.draft)).filter(
  (post) => post.data.project === project.id,
);
---

<ProjectDetailPage {project} {posts} locale="zh"><Content /></ProjectDetailPage>
