---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BlogPostLayout from '@/layouts/BlogPostLayout.astro';
import { byPublishedDesc } from '@/utils/content';

export async function getStaticPaths() {
  const posts = (await getCollection('blogEn', ({ data }) => !data.draft)).sort(byPublishedDesc);
  return posts.map((post, index) => ({
    params: { id: post.id },
    props: { post, previous: posts[index + 1], next: posts[index - 1] },
  }));
}

interface Props {
  post: CollectionEntry<'blogEn'>;
  previous?: CollectionEntry<'blogEn'>;
  next?: CollectionEntry<'blogEn'>;
}
const { post, previous, next } = Astro.props;
const { Content, headings } = await render(post);
---

<BlogPostLayout {post} {headings} {previous} {next} locale="en"><Content /></BlogPostLayout>
