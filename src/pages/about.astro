---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';
import { Image } from 'astro:assets';
import identityImage from '../../public/images/identity-42.png';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.author,
  url: site.url,
  sameAs: [site.github],
  knowsAbout: [
    'AI applications',
    'Agent workflows',
    'local-first software',
    'full-stack engineering',
  ],
};
---

<BaseLayout
  title="关于"
  description="关于 yuyukosama2004 与 execute42 的技术方向。"
  {structuredData}
>
  <section class="site-shell about">
    <div class="identity">
      <Image
        src={identityImage}
        alt="execute42 的 42 验证标记"
        width={768}
        height={768}
        format="webp"
        quality={82}
      />
    </div>
    <div>
      <p class="eyebrow">ABOUT</p>
      <h1 class="section-title">构建全栈 AI 产品，也为模型能力保留控制边界。</h1>
      <div class="prose">
        <p>
          我是 yuyukosama2004，一名全栈 AI 应用与 Agent 工程开发者。项目覆盖 Java 微服务、Vue
          前端、Python CLI、RAG、MCP 与自托管部署。
        </p>
        <p>
          我更关心的不只是模型能否生成结果，而是结果如何被约束、验证、追踪，并在出现问题时安全恢复。因此，测试、审批边界、来源记录、备份、回滚和运行状态会成为产品能力的一部分。
        </p>
        <p>
          当前案例包括带 RAG 导购的商城、可回滚的 Claude Code
          配置初始化器、证据驱动的研究工作台、长篇 AI
          写作工具，以及带确定性验证门禁的多模型开发流水线。
        </p>
        <a class="button primary" href={site.githubCta} target="_blank" rel="noreferrer"
          >在 GitHub 上找到我 ↗</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    display: grid;
    grid-template-columns: minmax(14rem, 0.55fr) minmax(0, 1fr);
    align-items: center;
    padding-block: 8rem 4rem;
    gap: clamp(3rem, 8vw, 8rem);
  }

  .about h1 {
    max-width: 16ch;
  }

  .prose {
    max-width: 40rem;
    margin-top: 3rem;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .prose p {
    margin: 0 0 1.4rem;
  }

  .identity img {
    display: block;
    width: 100%;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }

  @media (max-width: 42rem) {
    .about {
      grid-template-columns: 1fr;
      padding-top: 5rem;
    }
    .identity {
      max-width: 12rem;
    }
  }
</style>
