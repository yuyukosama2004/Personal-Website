---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';
import { Image } from 'astro:assets';
import identityImage from '../../public/images/identity-42.png';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.author,
  url: site.url,
  sameAs: [site.github],
  knowsAbout: [
    'AI applications',
    'Agent workflows',
    'local-first software',
    'full-stack engineering',
  ],
};
---

<BaseLayout
  title="关于"
  description="关于 yuyukosama2004 与 execute42 的技术方向。"
  {structuredData}
>
  <section class="site-shell about">
    <div class="identity">
      <Image
        src={identityImage}
        alt="execute42 的 42 验证标记"
        width={768}
        height={768}
        format="webp"
        quality={82}
      />
    </div>
    <div>
      <p class="eyebrow">ABOUT</p>
      <h1 class="section-title">把模型能力放进有边界、可验证的系统。</h1>
      <div class="prose">
        <p>
          我是 yuyukosama2004，关注 AI 应用、Agent
          开发工作流与全栈工程。我更在意模型输出如何被约束、验证和安全地交给人，而不只是调用一次模型接口。
        </p>
        <p>
          目前的项目覆盖长篇创作、证据驱动研究、多模型研发流水线和 RAG
          应用。这个网站用来展示这些项目，也记录它们背后的设计取舍与实际问题。
        </p>
        <a class="button primary" href={site.githubCta} target="_blank" rel="noreferrer"
          >在 GitHub 上找到我 ↗</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    display: grid;
    grid-template-columns: minmax(14rem, 0.55fr) minmax(0, 1fr);
    align-items: center;
    padding-block: 8rem 4rem;
    gap: clamp(3rem, 8vw, 8rem);
  }

  .about h1 {
    max-width: 16ch;
  }

  .prose {
    max-width: 40rem;
    margin-top: 3rem;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .prose p {
    margin: 0 0 1.4rem;
  }

  .identity img {
    display: block;
    width: 100%;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }

  @media (max-width: 42rem) {
    .about {
      grid-template-columns: 1fr;
      padding-top: 5rem;
    }
    .identity {
      max-width: 12rem;
    }
  }
</style>
