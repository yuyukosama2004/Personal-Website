---
import { site } from '@/config/site';
import { localizePath, sharedUi, type Locale } from '@/i18n';

const path = Astro.url.pathname;
interface Props {
  locale: Locale;
  languageHref: string;
}
const { locale, languageHref } = Astro.props;
const ui = sharedUi[locale];
const navigation = ui.navigation.map((item) => ({
  href: localizePath(item.path, locale),
  label: item.label,
}));
const normalizedPath = path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path;
const isCurrent = (href: string) =>
  normalizedPath === (href.endsWith('/') && href !== '/' ? href.slice(0, -1) : href);
---

<header class="site-header">
  <div class="site-shell header-inner">
    <a class="brand" href={localizePath('/', locale)}>
      <span aria-hidden="true">42</span>
      <strong>{site.name}</strong>
    </a>

    <nav aria-label={ui.navigationLabel}>
      <ul>
        {
          navigation.map((item) => (
            <li>
              <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      <a
        class="language-link"
        href={languageHref}
        lang={locale === 'zh' ? 'en' : 'zh-CN'}
        aria-label={ui.languageLabel}
      >
        {ui.languageShort}
      </a>
      <a class="search-link" href={localizePath('/search', locale)} aria-label={ui.searchLabel}>⌕</a
      >
      <button class="theme-toggle" type="button" data-theme-toggle aria-label={ui.themeLabel}>
        <span aria-hidden="true">◐</span>
      </button>
      <a class="github-link" href={site.githubCta} target="_blank" rel="noreferrer">GitHub ↗</a>
    </div>
  </div>
</header>

<script>
  const storageKey = 'execute42-theme';
  const button = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');

  button?.addEventListener('click', () => {
    const current = document.documentElement.dataset.theme;
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem(storageKey, next);
  });
</script>

<style>
  .site-header {
    position: sticky;
    z-index: 50;
    top: 0;
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg) 84%, transparent);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 4.5rem;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    text-decoration: none;
  }

  .brand span {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border-radius: 50%;
    background: var(--accent-strong);
    color: var(--bg);
    font-weight: 800;
  }

  nav ul {
    display: flex;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
    list-style: none;
  }

  nav a,
  .github-link,
  .search-link {
    display: inline-flex;
    min-height: 2.5rem;
    align-items: center;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 650;
    text-decoration: none;
  }

  .language-link {
    display: inline-flex;
    min-width: 2.5rem;
    min-height: 2.5rem;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 750;
    text-decoration: none;
  }

  .language-link:hover {
    border-color: var(--accent);
    color: var(--accent-strong);
  }

  nav a:hover,
  nav a[aria-current='page'] {
    background: var(--accent-soft);
    color: var(--accent-strong);
  }

  .header-actions {
    display: flex;
    align-items: center;
    justify-self: end;
    gap: 0.25rem;
  }

  .theme-toggle {
    display: grid;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    place-items: center;
    border: 0;
    border-radius: 50%;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    font-size: 1.15rem;
  }

  .search-link {
    width: 2.5rem;
    justify-content: center;
    padding: 0;
    color: var(--text);
    font-size: 1.2rem;
  }

  .search-link:hover {
    background: var(--accent-soft);
  }

  .theme-toggle:hover {
    background: var(--accent-soft);
  }

  @media (max-width: 46rem) {
    .site-header {
      background: var(--bg);
      backdrop-filter: none;
    }

    :global(body) {
      padding-bottom: 5rem;
    }

    .header-inner {
      grid-template-columns: auto 1fr auto;
    }

    nav {
      position: fixed;
      right: 1rem;
      bottom: 1rem;
      left: 1rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--surface-strong);
      box-shadow: var(--shadow);
    }

    nav ul {
      justify-content: space-around;
    }

    nav a {
      padding-inline: 0.5rem;
    }

    .github-link {
      font-size: 0;
    }

    .language-link {
      min-width: 2.25rem;
      min-height: 2.25rem;
    }

    .github-link::before {
      content: 'GH ↗';
      font-size: 0.78rem;
    }
  }
</style>
