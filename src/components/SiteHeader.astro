---
import { site } from '@/config/site';

const path = Astro.url.pathname;
const navigation = [
  { href: '/', label: '首页' },
  { href: '/projects', label: '项目' },
  { href: '/blog', label: '博客' },
  { href: '/search', label: '搜索' },
  { href: '/about', label: '关于' },
];
---

<header class="site-header">
  <div class="site-shell header-inner">
    <a class="brand" href="/" aria-label={`${site.name} 首页`}>
      <span aria-hidden="true">42</span>
      <strong>{site.name}</strong>
    </a>

    <nav aria-label="主要导航">
      <ul>
        {
          navigation.map((item) => (
            <li>
              <a href={item.href} aria-current={path === item.href ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="切换深色或浅色主题">
        <span aria-hidden="true">◐</span>
      </button>
      <a class="github-link" href={site.github} target="_blank" rel="noreferrer">GitHub ↗</a>
    </div>
  </div>
</header>

<script>
  const storageKey = 'execute42-theme';
  const button = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');

  button?.addEventListener('click', () => {
    const current = document.documentElement.dataset.theme;
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem(storageKey, next);
  });
</script>

<style>
  .site-header {
    position: sticky;
    z-index: 50;
    top: 0;
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg) 84%, transparent);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 4.5rem;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    text-decoration: none;
  }

  .brand span {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border-radius: 50%;
    background: var(--accent-strong);
    color: var(--bg);
    font-weight: 800;
  }

  nav ul {
    display: flex;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
    list-style: none;
  }

  nav a,
  .github-link {
    display: inline-flex;
    min-height: 2.5rem;
    align-items: center;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 650;
    text-decoration: none;
  }

  nav a:hover,
  nav a[aria-current='page'] {
    background: var(--accent-soft);
    color: var(--accent-strong);
  }

  .header-actions {
    display: flex;
    align-items: center;
    justify-self: end;
    gap: 0.25rem;
  }

  .theme-toggle {
    display: grid;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    place-items: center;
    border: 0;
    border-radius: 50%;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    font-size: 1.15rem;
  }

  .theme-toggle:hover {
    background: var(--accent-soft);
  }

  @media (max-width: 46rem) {
    .site-header {
      background: var(--bg);
      backdrop-filter: none;
    }

    :global(body) {
      padding-bottom: 5rem;
    }

    .header-inner {
      grid-template-columns: auto 1fr auto;
    }

    nav {
      position: fixed;
      right: 1rem;
      bottom: 1rem;
      left: 1rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--surface-strong);
      box-shadow: var(--shadow);
    }

    nav ul {
      justify-content: space-around;
    }

    nav a {
      padding-inline: 0.5rem;
    }

    .github-link {
      font-size: 0;
    }

    .github-link::before {
      content: 'GH ↗';
      font-size: 0.78rem;
    }
  }
</style>
