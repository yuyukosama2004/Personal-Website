---
import { getCollection } from 'astro:content';

import PostCard from '@/components/PostCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { site } from '@/config/site';
import { localizePath, localeMeta, type Locale } from '@/i18n';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { byProjectOrder, byPublishedDesc } from '@/utils/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const projectCollection = locale === 'zh' ? 'projects' : 'projectsEn';
const blogCollection = locale === 'zh' ? 'blog' : 'blogEn';
const projects = (await getCollection(projectCollection))
  .filter((project) => project.data.tier === 'featured')
  .sort(byProjectOrder);
const posts = (await getCollection(blogCollection, ({ data }) => !data.draft))
  .sort(byPublishedDesc)
  .slice(0, 3);
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebSite', name: site.name, url: site.url, inLanguage: localeMeta[locale].language },
    { '@type': 'Person', name: site.author, url: site.url, sameAs: [site.github] },
  ],
};
const copy = {
  zh: {
    eyebrow: '个人作品集 · 开发笔记',
    title: '你好，我是 yuyukosama2004。这里放着我做过的项目，也记录我是怎么把它们做出来的。',
    lede: '我主要用 Java、Vue 和 Python 做全栈开发，最近把更多精力放在 RAG、MCP 和 AI 工具上。比起只做一个能演示的原型，我更在意功能是否完整、问题能否查清，以及项目以后还能不能继续维护。',
    viewFeatured: '先看看项目',
    visitGithub: '去 GitHub',
    readNotes: '看看开发笔记',
    focusLabel: '最近在折腾',
    focus: ['PhoneMall 的 RAG 导购', 'GroundedSeek 研究工作台', 'Agent 开发工具和流程'],
    selectedEyebrow: '正在做的项目',
    selectedTitle: '有些已经能用，有些还在慢慢补完。',
    viewAllProjects: '查看全部项目',
    selectedLabel: '精选项目',
    capabilitiesEyebrow: '技术方向',
    capabilitiesTitle: '我平时主要做这些。',
    capabilities: [
      {
        title: '前后端一起做',
        body: '用 Java 或 Python 写服务端，用 Vue 或 React 做界面，再把数据库、接口和部署环境接起来。',
        tags: ['Java', 'Spring Cloud', 'Vue 3', 'Python', 'Docker'],
      },
      {
        title: '把 AI 接进具体功能',
        body: '我更关心 AI 能不能解决一个明确的问题，比如查商品、整理资料、辅助写作，而不只是接一个聊天框。',
        tags: ['RAG', 'MCP', 'SSE', 'Vector Search'],
      },
      {
        title: '让项目可以继续改',
        body: '写测试、接 CI、留日志，也准备好备份和回滚。这样改坏了能发现，出了问题也有地方可查。',
        tags: ['CI/CD', 'Testing', 'Audit', 'Rollback'],
      },
    ],
    methodEyebrow: '做项目的习惯',
    methodTitle: '我通常这样把想法一步步做出来。',
    workflow: [
      ['先弄清楚要解决什么', '先把使用场景和边界想明白，避免一上来就堆功能。'],
      ['先跑通一条完整流程', '从页面、接口到数据和部署，先让最重要的使用路径真正走通。'],
      ['再用测试把问题找出来', '能自动检查的尽量自动检查，重要结果则保留来源和记录。'],
      ['上线前想好怎么撤回来', '保留改动记录、备份和回滚办法，不把恢复寄托在临场发挥上。'],
    ],
    latestEyebrow: '开发笔记',
    latestTitle: '写下做项目时遇到的问题和想法。',
    readAll: '查看全部文章',
    closingEyebrow: '继续了解',
    closingTitle: '如果你想了解我，项目比自我介绍更直接。',
    closingBody:
      '网站会继续更新项目进展和开发笔记。公开的代码都放在 GitHub；暂时不能公开的项目，我也会尽量把思路、现状和限制说清楚。',
    about: '再认识一下我',
  },
  en: {
    eyebrow: 'FULL-STACK DEVELOPMENT · AI PRODUCTS',
    title: 'I build AI products that work beyond the demo.',
    lede: 'I work mainly with Java, Vue, and Python, bringing RAG, MCP, and language models into real product workflows. I care about the data, tests, deployment, and recovery path—not just the model call.',
    viewFeatured: 'View featured work',
    visitGithub: 'Visit GitHub',
    readNotes: 'Read engineering notes',
    focusLabel: 'Currently working on',
    focus: [
      'Full-stack applications',
      'RAG and intelligent search',
      'Testing, deployment, and recovery',
    ],
    selectedEyebrow: 'SELECTED WORK',
    selectedTitle: 'Projects explained through decisions, trade-offs, and evidence.',
    viewAllProjects: 'View all projects',
    selectedLabel: 'Featured projects',
    capabilitiesEyebrow: 'CAPABILITIES',
    capabilitiesTitle: 'From product requirements to a running deployment.',
    capabilities: [
      {
        title: 'Full-stack application development',
        body: 'I take products from domain models, APIs, and user interfaces through database migrations, containers, and self-hosted deployment.',
        tags: ['Java', 'Spring Cloud', 'Vue 3', 'Python', 'Docker'],
      },
      {
        title: 'RAG and intelligent search',
        body: 'I connect models to real data and build retrieval, citations, streaming responses, and evaluation into the workflow.',
        tags: ['RAG', 'MCP', 'SSE', 'Vector Search'],
      },
      {
        title: 'Quality and operations',
        body: 'Tests, CI, logs, backups, and rollback keep a project maintainable after the first successful demo.',
        tags: ['CI/CD', 'Testing', 'Audit', 'Rollback'],
      },
    ],
    methodEyebrow: 'HOW I WORK',
    methodTitle: 'Turning an idea into a product without losing control of it.',
    workflow: [
      [
        'Define the real problem',
        'Clarify the user need and identify which decisions must remain human.',
      ],
      [
        'Complete the workflow',
        'Connect the interface, APIs, data, model, and deployment environment.',
      ],
      [
        'Check the result',
        'Use automated tests, static checks, and source records to catch mistakes.',
      ],
      [
        'Plan for recovery',
        'Keep important changes traceable and make failures recoverable through backups and rollback.',
      ],
    ],
    latestEyebrow: 'LATEST WRITING',
    latestTitle: 'Notes from problems I have actually encountered while building.',
    readAll: 'View all articles',
    closingEyebrow: 'ABOUT EXECUTE42',
    closingTitle: 'Putting AI into products—not just into chat boxes.',
    closingBody:
      'I use this site to document projects, architecture decisions, and engineering lessons. Start with the case studies, or visit GitHub for the public code.',
    about: 'Learn more about me',
  },
}[locale];
const capabilities = copy.capabilities;
const workflow = copy.workflow;
---

<BaseLayout {locale} structuredData={structuredData}>
  <section class="site-shell hero">
    <div>
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1 class="display-title">{copy.title}</h1>
      <p class="lede">{copy.lede}</p>
      <div class="button-row">
        <a class="button primary" href={localizePath('/projects', locale)}>{copy.viewFeatured}</a>
        <a class="button" href={site.githubCta} target="_blank" rel="noreferrer"
          >{copy.visitGithub} ↗</a
        >
        <a class="text-link hero-note-link" href={localizePath('/blog', locale)}
          >{copy.readNotes} →</a
        >
      </div>
    </div>
    <aside class="signal-card panel" aria-label={copy.focusLabel}>
      <span class="status"><i></i> {copy.focusLabel}</span>
      <dl>
        {
          copy.focus.map((item, index) => (
            <div>
              <>
                <dt>{String(index + 1).padStart(2, '0')}</dt>
                <dd>{item}</dd>
              </>
            </div>
          ))
        }
      </dl>
    </aside>
  </section>

  <section class="site-shell section-heading">
    <div>
      <p class="eyebrow">{copy.selectedEyebrow}</p><h2 class="section-title">
        {copy.selectedTitle}
      </h2>
    </div>
    <a class="text-link" href={localizePath('/projects', locale)}>{copy.viewAllProjects} →</a>
  </section>
  <section class="site-shell project-grid" aria-label={copy.selectedLabel}>
    {projects.map((project, index) => <ProjectCard project={project} index={index} {locale} />)}
  </section>

  <section class="site-shell capability-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{copy.capabilitiesEyebrow}</p>
        <h2 class="section-title">{copy.capabilitiesTitle}</h2>
      </div>
    </div>
    <div class="capability-grid">
      {
        capabilities.map((capability, index) => (
          <article class="capability-card">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{capability.title}</h3>
            <p>{capability.body}</p>
            <ul aria-label={`${capability.title}技术`}>
              {capability.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="site-shell workflow-section">
    <div>
      <p class="eyebrow">{copy.methodEyebrow}</p>
      <h2 class="section-title">{copy.methodTitle}</h2>
    </div>
    <ol>
      {
        workflow.map(([title, body], index) => (
          <li>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h3>{title}</h3>
              <p>{body}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="site-shell notes-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{copy.latestEyebrow}</p><h2 class="section-title">{copy.latestTitle}</h2>
      </div><a class="text-link" href={localizePath('/blog', locale)}>{copy.readAll} →</a>
    </div>
    <div>{posts.map((post) => <PostCard post={post} {locale} />)}</div>
  </section>

  <section class="site-shell closing panel">
    <div>
      <p class="eyebrow">{copy.closingEyebrow}</p>
      <h2 class="section-title">{copy.closingTitle}</h2>
      <p>{copy.closingBody}</p>
    </div>
    <div class="button-row">
      <a class="button primary" href={localizePath('/about', locale)}>{copy.about}</a>
      <a class="button" href={localizePath('/projects', locale)}>{copy.viewAllProjects}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    min-height: min(49rem, calc(100vh - 4.5rem));
    grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.55fr);
    align-items: center;
    gap: clamp(2rem, 7vw, 7rem);
    padding-block: 6rem;
  }
  .lede {
    margin: 2rem 0;
  }
  .display-title {
    overflow-wrap: anywhere;
  }
  .hero-note-link {
    align-self: center;
    margin-left: 0.25rem;
  }
  .signal-card {
    padding: 1.35rem;
    transform: rotate(1.5deg);
  }
  .status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .status i {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0.28rem var(--accent-soft);
  }
  dl {
    margin: 3.5rem 0 0;
  }
  dl div {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    padding: 1rem 0;
    border-top: 1px solid var(--line);
    gap: 0.75rem;
  }
  dt {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }
  dd {
    margin: 0;
    font-weight: 700;
  }
  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
  }
  section.section-heading {
    padding-block: 5rem 2rem;
  }
  .section-heading h2 {
    max-width: 18ch;
  }
  .text-link {
    color: var(--accent-strong);
    font-weight: 700;
    white-space: nowrap;
  }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .capability-section,
  .workflow-section {
    padding-block: 8rem 2rem;
  }
  .capability-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 2.5rem;
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }
  .capability-card {
    padding: 1.5rem;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .capability-card > span,
  .workflow-section li > span {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }
  .capability-card h3,
  .workflow-section h3 {
    margin: 2rem 0 0.6rem;
    font-size: 1.25rem;
  }
  .capability-card p,
  .workflow-section p,
  .closing p {
    color: var(--muted);
  }
  .capability-card ul {
    display: flex;
    flex-wrap: wrap;
    margin: 1.5rem 0 0;
    padding: 0;
    gap: 0.4rem;
    list-style: none;
  }
  .capability-card li {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }
  .workflow-section {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(3rem, 8vw, 8rem);
  }
  .workflow-section ol {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .workflow-section li {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    padding: 1.25rem 0;
    border-top: 1px solid var(--line);
    gap: 1rem;
  }
  .workflow-section h3 {
    margin: 0;
  }
  .workflow-section p {
    margin: 0.4rem 0 0;
  }
  .notes-section {
    padding-block: 8rem 5rem;
  }
  .notes-section > .section-heading {
    margin-bottom: 2rem;
  }
  .closing {
    display: flex;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 6rem;
    padding: clamp(1.5rem, 5vw, 3.5rem);
    gap: 3rem;
  }
  .closing p:not(.eyebrow) {
    max-width: 42rem;
    margin-bottom: 0;
  }
  @media (max-width: 52rem) {
    .hero {
      min-height: auto;
      grid-template-columns: 1fr;
      padding-block: 5rem;
    }
    .signal-card {
      transform: none;
    }
    .project-grid {
      grid-template-columns: 1fr;
    }
    .capability-grid {
      grid-template-columns: 1fr;
    }
    .workflow-section {
      grid-template-columns: 1fr;
    }
    .closing {
      align-items: start;
      flex-direction: column;
    }
  }
  @media (max-width: 36rem) {
    .section-heading {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
