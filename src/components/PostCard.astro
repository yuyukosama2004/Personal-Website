---
import type { CollectionEntry } from 'astro:content';

import { localizePath, type Locale } from '@/i18n';
import { formatDate } from '@/utils/content';
import { getReadingTime } from '@/utils/reading-time';

interface Props {
  post: CollectionEntry<'blog'> | CollectionEntry<'blogEn'>;
  locale?: Locale;
}

const { post, locale = 'zh' } = Astro.props;
const minutes = getReadingTime(post.body ?? '');
---

<article class="post-card">
  <a href={localizePath(`/blog/${post.id}/`, locale)}>
    <div class="post-meta">
      <time datetime={post.data.publishedAt.toISOString()}
        >{formatDate(post.data.publishedAt, locale)}</time
      >
      <span>{locale === 'zh' ? `约 ${minutes} 分钟` : `${minutes} min read`}</span>
    </div>
    <h3>{post.data.title}</h3>
    <p>{post.data.description}</p>
    <ul aria-label={locale === 'zh' ? '文章标签' : 'Article tags'}>
      {post.data.tags.map((tag) => <li>{tag}</li>)}
    </ul>
  </a>
</article>

<style>
  .post-card {
    border-top: 1px solid var(--line);
  }

  a {
    display: grid;
    grid-template-columns: 11rem minmax(0, 1fr);
    padding: 1.65rem 0;
    gap: 1rem 2rem;
    text-decoration: none;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    gap: 0.25rem;
  }

  h3 {
    margin: 0;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    letter-spacing: -0.035em;
  }

  p {
    grid-column: 2;
    margin: -0.35rem 0 0;
    color: var(--muted);
  }

  ul {
    display: flex;
    grid-column: 2;
    margin: 0;
    padding: 0;
    gap: 0.65rem;
    list-style: none;
  }

  li {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  li::before {
    content: '#';
  }

  a:hover h3 {
    color: var(--accent-strong);
  }

  @media (max-width: 42rem) {
    a {
      grid-template-columns: 1fr;
    }

    .post-meta {
      flex-direction: row;
      justify-content: space-between;
    }

    p,
    ul {
      grid-column: 1;
    }
  }
</style>
